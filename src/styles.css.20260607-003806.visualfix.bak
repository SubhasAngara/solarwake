:root {
  --bg: #030711;
  --ink: #eef6ff;
  --muted: #b9c7d6;
  --soft: rgba(238, 246, 255, 0.72);
  --cyan: #6fffe6;
  --sky: #77c8ff;
  --rose: #f0a0c8;
  --gold: #f4d27a;
  --panel: rgba(7, 13, 24, 0.44);
  --panel-strong: rgba(8, 14, 26, 0.66);
  --stroke: rgba(238, 246, 255, 0.16);
  --shadow: 0 28px 90px rgba(0, 0, 0, 0.38);
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

* {
  box-sizing: border-box;
}

html {
  min-height: 100%;
  background: var(--bg);
  color: var(--ink);
}

body {
  min-height: 100vh;
  margin: 0;
  overflow-x: hidden;
  background: var(--bg);
}

button {
  font: inherit;
}

.space-scene,
.space-scene > * {
  position: fixed;
  inset: 0;
}

.space-scene {
  z-index: -2;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(3, 7, 17, 0.88), rgba(4, 14, 25, 0.86) 44%, rgba(4, 19, 28, 0.96)),
    radial-gradient(circle at 70% 18%, rgba(244, 210, 122, 0.28), transparent 22%),
    radial-gradient(circle at 28% 82%, rgba(111, 255, 230, 0.18), transparent 28%),
    #030711;
}

.space-glow {
  filter: blur(28px);
  opacity: 0.75;
  transform-origin: center;
  animation: slow-drift 18s ease-in-out infinite alternate;
}

.glow-one {
  inset: 10% 8% auto auto;
  width: 48vw;
  height: 34vh;
  border-radius: 999px;
  background: linear-gradient(100deg, rgba(111, 255, 230, 0.08), rgba(240, 160, 200, 0.32), rgba(244, 210, 122, 0.3));
}

.glow-two {
  inset: auto auto 2% 24%;
  width: 52vw;
  height: 24vh;
  border-radius: 999px;
  background: linear-gradient(100deg, rgba(111, 255, 230, 0.3), rgba(119, 200, 255, 0.24), transparent);
  animation-delay: -5s;
}

.glow-three {
  inset: 18% auto auto -10%;
  width: 38vw;
  height: 52vh;
  border-radius: 999px;
  background: rgba(119, 200, 255, 0.13);
  animation-delay: -9s;
}

.star-layer {
  background-repeat: repeat;
  opacity: 0.95;
}

.stars-slow {
  background-image:
    radial-gradient(circle, rgba(255, 255, 255, 0.86) 0 1px, transparent 1.6px),
    radial-gradient(circle, rgba(119, 200, 255, 0.64) 0 1px, transparent 1.8px);
  background-size: 92px 92px, 151px 151px;
  animation: stars-pan 42s linear infinite;
}

.stars-fast {
  background-image:
    radial-gradient(circle, rgba(255, 255, 255, 0.54) 0 1px, transparent 1.5px),
    radial-gradient(circle, rgba(244, 210, 122, 0.5) 0 1px, transparent 1.5px);
  background-size: 64px 64px, 118px 118px;
  opacity: 0.55;
  animation: stars-pan 24s linear infinite reverse;
}

.dust-field {
  background:
    linear-gradient(90deg, transparent, rgba(238, 246, 255, 0.08), transparent),
    linear-gradient(180deg, transparent 30%, rgba(111, 255, 230, 0.06), transparent 70%);
  mask-image: radial-gradient(ellipse at center, black 0 44%, transparent 72%);
  opacity: 0.9;
  animation: dust-breathe 8s ease-in-out infinite alternate;
}

.background-mascot {
  pointer-events: none;
  object-fit: contain;
  filter: drop-shadow(0 24px 50px rgba(0, 0, 0, 0.42));
  user-select: none;
}

.mascot-drift {
  inset: auto auto 17vh 12vw;
  width: clamp(150px, 18vw, 300px);
  height: auto;
  opacity: 0.9;
  animation: mascot-float 8s ease-in-out infinite;
}

.mascot-peek {
  inset: 12vh 34vw auto auto;
  width: clamp(68px, 8vw, 120px);
  height: auto;
  opacity: 0.62;
  transform: rotate(13deg);
  animation: mascot-peek 10s ease-in-out infinite;
}

.shell {
  position: relative;
  min-height: 100vh;
  isolation: isolate;
}

.view {
  min-height: 100vh;
  padding: clamp(22px, 5vw, 76px);
  opacity: 0;
  transform: translateY(14px);
  transition: opacity 420ms ease, transform 420ms ease;
}

.view.is-active {
  opacity: 1;
  transform: translateY(0);
}

.home-view {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.home-panel {
  width: min(420px, 100%);
  padding: clamp(28px, 4vw, 48px);
  background: linear-gradient(90deg, rgba(5, 10, 18, 0.1), var(--panel));
  border-left: 1px solid var(--stroke);
  border-radius: 2px;
  box-shadow: var(--shadow);
  backdrop-filter: blur(18px);
}

.eyebrow {
  margin: 0 0 12px;
  color: var(--cyan);
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0;
  text-transform: uppercase;
}

.solar-logo {
  display: flex;
  align-items: center;
  gap: 1px;
  margin: 0;
  color: var(--ink);
  font-size: clamp(3.2rem, 9vw, 6.4rem);
  font-weight: 700;
  line-height: 0.9;
  letter-spacing: 0;
}

.logo-orbit {
  position: relative;
  display: inline-grid;
  width: 0.82em;
  height: 0.82em;
  place-items: center;
  margin: 0 0.02em;
  border: 0.045em solid rgba(238, 246, 255, 0.78);
  border-radius: 50%;
  box-shadow: inset 0 0 0 0.055em rgba(111, 255, 230, 0.18), 0 0 34px rgba(111, 255, 230, 0.18);
  transform: translateY(0.04em);
  overflow: hidden;
}

.logo-orbit::after {
  content: "";
  position: absolute;
  width: 125%;
  height: 34%;
  border: 0.035em solid rgba(119, 200, 255, 0.42);
  border-left-color: transparent;
  border-right-color: transparent;
  border-radius: 50%;
  transform: rotate(-18deg);
}

.logo-orbit img {
  position: relative;
  z-index: 1;
  width: 78%;
  height: 78%;
  object-fit: contain;
}

.intro {
  max-width: 29rem;
  margin: 24px 0 0;
  color: var(--soft);
  font-size: clamp(1rem, 2vw, 1.15rem);
  line-height: 1.65;
}

.home-actions {
  display: grid;
  gap: 14px;
  margin-top: 34px;
}

.menu-button,
.back-button {
  min-height: 48px;
  border: 1px solid rgba(238, 246, 255, 0.18);
  border-radius: 3px;
  color: var(--ink);
  background: rgba(238, 246, 255, 0.08);
  cursor: pointer;
  transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
}

.menu-button {
  width: 100%;
  padding: 0 18px;
  text-align: left;
  font-weight: 750;
}

.menu-button.primary {
  color: #05111a;
  border-color: transparent;
  background: linear-gradient(135deg, var(--cyan), var(--sky));
}

.menu-button:hover,
.back-button:hover,
.mission-card:hover {
  transform: translateY(-2px);
  border-color: rgba(111, 255, 230, 0.5);
}

.info-note {
  margin: 22px 0 0;
  color: var(--muted);
  line-height: 1.55;
}

.mission-view {
  display: grid;
  place-items: center;
}

.mission-shell {
  width: min(1160px, 100%);
  padding: clamp(18px, 3vw, 28px);
  background: rgba(4, 10, 19, 0.48);
  border: 1px solid var(--stroke);
  border-radius: 6px;
  box-shadow: var(--shadow);
  backdrop-filter: blur(18px);
}

.mission-topbar {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 22px;
}

.back-button {
  min-width: 78px;
  padding: 0 14px;
}

.mission-topbar h2 {
  margin: 0;
  font-size: clamp(1.6rem, 4vw, 2.8rem);
  line-height: 1;
  letter-spacing: 0;
}

.mission-layout {
  display: grid;
  grid-template-columns: minmax(250px, 380px) minmax(0, 1fr);
  gap: clamp(18px, 3vw, 34px);
}

.mission-list {
  display: grid;
  gap: 12px;
}

.mission-card {
  display: grid;
  gap: 9px;
  width: 100%;
  padding: 16px;
  color: var(--ink);
  text-align: left;
  border: 1px solid rgba(238, 246, 255, 0.14);
  border-radius: 4px;
  background: rgba(238, 246, 255, 0.07);
  cursor: pointer;
  transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
}

.mission-card.is-selected {
  border-color: rgba(111, 255, 230, 0.78);
  background: linear-gradient(135deg, rgba(111, 255, 230, 0.18), rgba(119, 200, 255, 0.08));
}

.mission-card span {
  width: fit-content;
  padding: 5px 8px;
  color: var(--cyan);
  border: 1px solid rgba(111, 255, 230, 0.32);
  border-radius: 999px;
  font-size: 0.7rem;
  font-weight: 850;
}

.mission-card strong {
  font-size: 1rem;
}

.mission-card small {
  color: var(--muted);
  line-height: 1.45;
}

.viewer-panel {
  display: grid;
  grid-template-rows: auto minmax(340px, 1fr);
  min-height: 100%;
  overflow: hidden;
  border: 1px solid rgba(238, 246, 255, 0.12);
  border-radius: 5px;
  background: linear-gradient(140deg, rgba(238, 246, 255, 0.1), rgba(7, 13, 24, 0.5));
}

.viewer-copy {
  padding: 20px 22px 0;
}

.viewer-copy h3 {
  margin: 0;
  font-size: clamp(1.5rem, 3vw, 2.5rem);
  letter-spacing: 0;
}

.viewer-copy p:last-child {
  max-width: 36rem;
  margin: 10px 0 0;
  color: var(--muted);
  line-height: 1.55;
}

.viewer-frame {
  --rx: -14deg;
  --ry: 24deg;
  position: relative;
  display: grid;
  min-height: 340px;
  place-items: center;
  overflow: hidden;
  cursor: grab;
  perspective: 900px;
}

.viewer-frame:active {
  cursor: grabbing;
}

.viewer-frame::before {
  content: "";
  position: absolute;
  inset: 10%;
  background-image:
    linear-gradient(rgba(238, 246, 255, 0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(238, 246, 255, 0.05) 1px, transparent 1px);
  background-size: 36px 36px;
  mask-image: radial-gradient(circle, black, transparent 70%);
}

.orbit {
  position: absolute;
  width: 62%;
  aspect-ratio: 1;
  border: 1px solid rgba(238, 246, 255, 0.16);
  border-radius: 50%;
}

.orbit-a {
  transform: rotateX(64deg) rotateZ(-22deg);
}

.orbit-b {
  transform: rotateX(72deg) rotateZ(42deg);
  animation: orbit-roll 13s linear infinite;
}

.mission-model {
  position: relative;
  width: 170px;
  height: 170px;
  transform-style: preserve-3d;
  transform: rotateX(var(--rx)) rotateY(var(--ry));
  transition: transform 120ms ease-out;
}

.model-part {
  position: absolute;
  left: 50%;
  top: 50%;
  transform-style: preserve-3d;
  box-shadow: 0 18px 44px rgba(0, 0, 0, 0.24);
}

.model-shadow {
  position: absolute;
  left: 50%;
  top: 82%;
  width: 140px;
  height: 34px;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.28);
  filter: blur(14px);
  transform: translate3d(-50%, -50%, -90px) rotateX(88deg);
}

.part-main {
  width: 86px;
  height: 86px;
  border-radius: 24px;
  background: linear-gradient(145deg, #f8fbff, #95b5cf);
  transform: translate3d(-50%, -50%, 28px);
}

.part-top,
.part-bottom {
  width: 46px;
  height: 54px;
  border-radius: 24px;
  background: linear-gradient(145deg, var(--cyan), var(--sky));
  transform: translate3d(-50%, -120px, 0);
}

.part-bottom {
  transform: translate3d(-50%, 68px, 0);
}

.part-left,
.part-right {
  width: 64px;
  height: 20px;
  border-radius: 999px;
  background: linear-gradient(145deg, #ffffff, #9bb7cf);
  transform: translate3d(-116px, -50%, 8px) rotateZ(-18deg);
}

.part-right {
  transform: translate3d(52px, -50%, 8px) rotateZ(18deg);
}

.model-iss .part-main,
.model-gps .part-main,
.model-cubesat .part-main {
  width: 70px;
  height: 70px;
  border-radius: 8px;
  background: linear-gradient(145deg, #dbe8f7, #748da6);
}

.model-iss .part-left,
.model-iss .part-right,
.model-gps .part-left,
.model-gps .part-right {
  width: 130px;
  height: 52px;
  border-radius: 4px;
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.22) 1px, transparent 1px),
    linear-gradient(145deg, #254d88, #6fffe6);
  background-size: 22px 100%, auto;
}

.model-iss .part-left,
.model-gps .part-left {
  transform: translate3d(-172px, -50%, 0) rotateY(-18deg);
}

.model-iss .part-right,
.model-gps .part-right {
  transform: translate3d(42px, -50%, 0) rotateY(18deg);
}

.model-iss .part-top,
.model-iss .part-bottom,
.model-gps .part-top,
.model-gps .part-bottom {
  width: 28px;
  height: 88px;
  border-radius: 999px;
  background: linear-gradient(180deg, #f8fbff, #93abc2);
}

.model-artemis .part-main,
.model-mars .part-main {
  width: 92px;
  height: 112px;
  border-radius: 50% 50% 38% 38%;
  background: linear-gradient(145deg, #f9f5eb, #b7c4ce);
}

.model-artemis .part-top,
.model-mars .part-top {
  width: 76px;
  height: 42px;
  border-radius: 50% 50% 14px 14px;
  background: linear-gradient(145deg, #ffffff, var(--gold));
  transform: translate3d(-50%, -118px, 0);
}

.model-artemis .part-left,
.model-artemis .part-right,
.model-mars .part-left,
.model-mars .part-right {
  width: 42px;
  height: 96px;
  border-radius: 999px;
  background: linear-gradient(145deg, var(--rose), var(--sky));
}

.model-cubesat .part-left,
.model-cubesat .part-right {
  width: 70px;
  height: 70px;
  border-radius: 8px;
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.2) 1px, transparent 1px),
    linear-gradient(0deg, rgba(255, 255, 255, 0.2) 1px, transparent 1px),
    linear-gradient(145deg, #2e647e, #6fffe6);
  background-size: 18px 18px, 18px 18px, auto;
}

.model-cubesat .part-top,
.model-cubesat .part-bottom {
  width: 42px;
  height: 42px;
  border-radius: 8px;
}

.drag-hint {
  position: absolute;
  right: 18px;
  bottom: 16px;
  margin: 0;
  color: rgba(238, 246, 255, 0.62);
  font-size: 0.82rem;
}

@keyframes slow-drift {
  from {
    transform: translate3d(-1.5vw, -1vh, 0) scale(1);
  }

  to {
    transform: translate3d(2vw, 1.6vh, 0) scale(1.06);
  }
}

@keyframes stars-pan {
  to {
    background-position: 240px 180px, -180px 220px;
  }
}

@keyframes dust-breathe {
  to {
    opacity: 0.55;
    transform: scale(1.04);
  }
}

@keyframes mascot-float {
  0%,
  100% {
    transform: translate3d(0, 0, 0) rotate(-7deg);
  }

  50% {
    transform: translate3d(3vw, -4vh, 0) rotate(7deg);
  }
}

@keyframes mascot-peek {
  0%,
  100% {
    transform: translate3d(0, 0, 0) rotate(13deg);
  }

  50% {
    transform: translate3d(-2vw, 3vh, 0) rotate(2deg);
  }
}

@keyframes orbit-roll {
  to {
    transform: rotateX(72deg) rotateZ(402deg);
  }
}

@media (max-width: 860px) {
  .home-view {
    align-items: flex-end;
    justify-content: center;
  }

  .home-panel {
    background: var(--panel-strong);
    border: 1px solid var(--stroke);
  }

  .mascot-drift {
    inset: 12vh auto auto 8vw;
    width: 190px;
  }

  .mascot-peek {
    display: none;
  }

  .mission-layout {
    grid-template-columns: 1fr;
  }

  .mission-list {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 560px) {
  .view {
    padding: 16px;
  }

  .solar-logo {
    font-size: clamp(2.7rem, 15vw, 4.4rem);
  }

  .mission-topbar {
    align-items: flex-start;
    flex-direction: column;
  }

  .mission-list {
    grid-template-columns: 1fr;
  }

  .viewer-panel {
    grid-template-rows: auto 300px;
  }
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.001ms !important;
    animation-iteration-count: 1 !important;
    scroll-behavior: auto !important;
    transition-duration: 0.001ms !important;
  }
}
